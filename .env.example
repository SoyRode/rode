# ==================== CONFIGURACIÓN DE ENTORNO ====================
# Este archivo contiene variables de configuración para la aplicación
# NO COMPARTIR EN REPOSITORIO - agregar a .gitignore

# ==================== MODO DE EJECUCIÓN ====================
# Valores: development, staging, production
ENV=development

# ==================== SERVIDOR BACKEND ====================
# URL del servidor que proporciona índices (IPC, UI, UR)
# En desarrollo: http://localhost:3000
# En producción: https://api.itpirpf.com
BACKEND_URL=http://localhost:3000

# API Key para autenticación con el backend (si es necesario)
API_KEY=tu_api_key_aqui

# ==================== DATOS OFICIALES URUGUAYOS ====================
# URLs de fuentes oficiales para obtener índices

# INE - Instituto Nacional de Estadística
# URL para obtener IPC (Índice de Precios al Consumidor)
INE_API_URL=https://www.ine.gub.uy/

# BCU - Banco Central del Uruguay
# URL para obtener UI (Índice de Unidad Reajustable) y cotización USD
BCU_API_URL=https://www.bcu.gub.uy/

# MVOTMA - Ministerio de Vivienda, Ordenamiento Territorial y Medio Ambiente
# URL para obtener UR (Unidad Reajustable)
MVOTMA_API_URL=https://www.mvotma.gub.uy/

# ==================== BASE DE DATOS LOCAL ====================
# La app usa Hive para almacenamiento local por defecto
# No requiere configuración externa

# Nombre de la caja Hive para operaciones
HIVE_BOX_OPERATIONS=operations

# Nombre de la caja Hive para índices
HIVE_BOX_INDEXES=indexes

# Nombre de la caja Hive para preferencias
HIVE_BOX_PREFERENCES=preferences

# ==================== CONFIGURACIÓN DE LA APP ====================

# Modo offline - si true, no intenta conectar a internet
OFFLINE_MODE=false

# Cachear índices por X días (antes de considerar desactualizado)
CACHE_EXPIRATION_DAYS=7

# Tiempo máximo para timeout de peticiones HTTP (en segundos)
HTTP_TIMEOUT_SECONDS=30

# ==================== DEBUGGING ====================
# Nivel de logging: debug, info, warning, error
LOG_LEVEL=info

# Habilitar logs detallados en desarrollo
DEBUG_LOGS=true

# Sentry DSN para reporte de errores (opcional)
SENTRY_DSN=

# ==================== INFORMACIÓN DE LA APP ====================
# Versión de la aplicación
APP_VERSION=1.0.0

# Nombre de la aplicación
APP_NAME=ITP-IRPF Calculator

# Email de soporte
SUPPORT_EMAIL=soporte@itpirpf.com

# Sitio web
WEBSITE_URL=https://www.itpirpf.com

# ==================== FUNCIÓN Y EXPLICACIÓN ====================
#
# NOTAS IMPORTANTES:
#
# 1. En desarrollo: Usar valores de localhost y desarrollo
# 2. En producción: Cambiar a URLs seguras (HTTPS) y producción
# 3. NUNCA compartir API_KEY o contraseñas en repositorio
# 4. Usar variables de entorno de plataforma para datos sensibles
# 5. En CI/CD, inyectar estas variables de forma segura
#
# CÓMO USAR:
#
# a) Duplicar este archivo y renombrarlo a .env
# b) Editar valores según el entorno
# c) En Flutter, cargar con: dotenv.env['VARIABLE_NAME']
#
# EJEMPLO EN CÓDIGO:
#
# ```dart
# import 'package:flutter_dotenv/flutter_dotenv.dart';
#
# void main() {
#   dotenv.load();
#   runApp(const MyApp());
# }
#
# // Acceder a variables
# String backendUrl = dotenv.env['BACKEND_URL'] ?? 'http://localhost:3000';
# ```
#
# ==================== FIN DE CONFIGURACIÓN ====================
